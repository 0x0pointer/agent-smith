{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-compact.sh\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(ps aux*)",
      "Bash(curl -s *)",
      "Bash(curl -s*)",
      "Bash(wc -*)",
      "Bash(lsof -i *)",
      "Bash(poetry env info*)",
      "Bash(poetry env list*)",
      "Bash(ping -c *)",
      "Bash(open *)"
    ]
  }
}
