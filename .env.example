# API keys for AI red-teaming tools (FuzzyAI, PyRIT, Garak)
# Copy this file to .env and fill in your keys:
#   cp .env.example .env && chmod 600 .env
#
# Keys are loaded automatically by the MCP server.
# Leave blank or remove lines you don't need.

OPENAI_API_KEY=
# Anthropic key for the AI red-team tools ONLY. Named AITEST_ (not ANTHROPIC_API_KEY) on purpose so an
# interactive `claude` can't pick it up and bill your Smith agent's model calls to it — the server
# re-exposes it as ANTHROPIC_API_KEY internally for FuzzyAI/PyRIT + the QA agent.
AITEST_ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=

# ── Smith agent model auth ───────────────────────────────────────────────────
# Leave unset (default) → the Smith agent runs on your Claude SUBSCRIPTION. Set both of these to bill
# the agent (interactive + headless) to an API key instead. Only set ANTHROPIC_API_KEY here if you want
# the agent on the API — it will also make an interactive `claude` bill that key.
# SMITH_USE_API_KEY=yes
# SMITH_SPAWN_USE_API_KEY=1
# ANTHROPIC_API_KEY=

# ── Telegram bridge (optional) ───────────────────────────────────────────────
# Get HIR / scan-complete alerts on your phone. Leave both blank to disable —
# the notifier is a runtime no-op when either value is missing.
#
# PREREQUISITE: install the Telegram app (https://telegram.org/apps —
# mobile, desktop, or web). The setup below is done INSIDE Telegram:
#   1. Open a chat with @BotFather → send /newbot → follow prompts →
#      copy the token shown ("123456:ABC-…") into TELEGRAM_BOT_TOKEN.
#   2. Search for your new bot → open the chat → send /start, then send any
#      text message (e.g. "hi"). Telegram's getUpdates endpoint only returns
#      real messages — pressing /start alone may not surface the chat.
#   3. In any browser, visit https://api.telegram.org/bot<TOKEN>/getUpdates
#      and copy the "chat":{"id": …} value (positive int for direct chats)
#      into TELEGRAM_CHAT_ID. If the response is {"result":[]}, send another
#      message in Telegram and refresh.
#
# Security: outbound HTTPS only, no public URL needed, never sends finding
# bodies (only counts and short HIR situation strings), dedups identical
# alerts within 30 min. Audit log at logs/telegram_audit.log.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Slack bridge (optional) ──────────────────────────────────────────────────
# Same outbound-only alerts via a Slack Incoming Webhook. Leave blank to
# disable. Any combination of Telegram/Slack/Discord can be enabled at once.
#
# Setup (inside Slack):
#   1. https://api.slack.com/apps → Create New App → From scratch.
#   2. Activate Incoming Webhooks → Add New Webhook to Workspace.
#   3. Pick the channel that should receive alerts (a private DM is fine).
#   4. Copy the webhook URL — it looks like
#      https://hooks.slack.com/services/T…/B…/…  → paste below.
#
# Security: outbound HTTPS only, never sends finding bodies, dedups identical
# alerts within 30 min. Audit log at logs/slack_audit.log.
SLACK_WEBHOOK_URL=

# ── Discord bridge (optional) ────────────────────────────────────────────────
# Same outbound-only alerts via a Discord channel webhook. Leave blank to
# disable.
#
# Setup (inside Discord):
#   1. Open the channel that should receive alerts.
#   2. Channel settings → Integrations → Webhooks → New Webhook.
#   3. Name it (e.g. "agent-smith"), confirm the channel, copy the webhook URL.
#      It looks like https://discord.com/api/webhooks/<id>/<token>.
#
# Security: outbound HTTPS only, @everyone/@here mentions disabled defensively,
# dedups identical alerts within 30 min. Audit log at logs/discord_audit.log.
DISCORD_WEBHOOK_URL=

# ── Periodic status updates ──────────────────────────────────────────────────
# Every N minutes the dashboard pushes a high-level scan summary
# (finding counts by severity, skills run, coverage %, activity, cost,
# runtime) to every configured notifier sink above. The summary contains
# NO target, NO finding titles, NO endpoint paths — counts and percentages
# only.
#
# Defaults to 30 minutes. Set to 0 to disable status pings entirely; idle
# scans (no active session) never trigger a ping regardless of the value.
STATUS_UPDATE_INTERVAL_MINUTES=30

# ── Out-of-band (OOB) interaction backend ────────────────────────────────────
# Confirms BLIND vulnerabilities (blind SSRF / RCE / XXE / OAST-based SQLi, DNS
# exfil) via the session(action='oob_start'|'oob_mint'|'oob_poll') lifecycle.
# The backend is PLUGGABLE — interactsh is the default, not a requirement.
#
# OOB_MODE = interactsh (default) | http
#
#   interactsh — full DNS + HTTP(S) (+SMTP) callbacks via the interactsh-client
#     bundled in the Kali image. DNS matters for egress-filtered / truly blind
#     targets that can resolve a hostname but can't open an outbound HTTP conn.
#       OOB_SERVER_URL blank → interactsh PUBLIC servers (oast.fun, …; data
#         transits ProjectDiscovery — fine for most testing).
#       OOB_SERVER_URL set   → your OWN self-hosted interactsh-server on a public
#         VPS (e.g. https://oob.example.com) so callbacks stay on infra you own.
#       OOB_SERVER_TOKEN     → only if that self-hosted server is auth-protected.
#
#   http — ANY plain HTTP request logger (e.g. https://oob-logger.example.com,
#     webhook.site, RequestBin, or a one-line server you run). Zero infra, but
#     HTTP(S)-only (no DNS). Set:
#       OOB_MODE=http
#       OOB_SERVER_URL=https://oob-logger.example.com   # callback base URL
#       OOB_POLL_URL=https://oob-logger.example.com/logs/{id}   # optional: the
#         endpoint that returns the server's request log so polling is automatic;
#         '{id}' is replaced with the per-test correlation id. Omit it and
#         oob_poll just tells you which path to look for in the logger's own UI.
#
# Either mode sidesteps NAT — nothing inbound is needed on your machine.
OOB_MODE=
OOB_SERVER_URL=
OOB_SERVER_TOKEN=
OOB_POLL_URL=

# ── Model profile (context / output scaling) ─────────────────────────────────
# Smith scales its context budgets, completion-blocker delivery, adjudication
# directive size, and required thorough-pass count to the driving model:
#   full   — large-context cloud models (Claude, GPT-4/5, Gemini). The default.
#   medium — ~40K-token-class models.
#   small  — ~16-32K-token LOCAL models (e.g. Qwen3-27B, Llama-3-8B): tighter
#            budgets, completion blockers surfaced one-at-a-time, condensed
#            directives, fewer thorough passes.
#
# AUTO-DETECTED when blank: a local model is inferred from OLLAMA_HOST, or a
# model name in OPENCODE_MODEL / OLLAMA_MODEL / MODEL (qwen/llama/mistral/… →
# small, or medium for >=65B); otherwise → full. The MCP server loads THIS file
# into its environment, so setting the profile here applies on EVERY client
# (Claude Code / opencode / Codex). This matters because opencode and Codex do
# NOT pass their configured model name to the server — so when you drive Smith
# with a small LOCAL model on those clients, set this explicitly (or set
# OLLAMA_HOST) or it will assume `full` and overflow the model's context.
#
# Leave blank to auto-detect, or force one of: full | medium | small
SMITH_MODEL_PROFILE=
