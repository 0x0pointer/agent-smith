# API keys for AI red-teaming tools (FuzzyAI, PyRIT, Garak)
# Copy this file to .env and fill in your keys:
#   cp .env.example .env && chmod 600 .env
#
# Keys are loaded automatically by the MCP server.
# Leave blank or remove lines you don't need.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=

# ── Telegram bridge (optional) ───────────────────────────────────────────────
# Get HIR / scan-complete alerts on your phone. Leave both blank to disable —
# the notifier is a runtime no-op when either value is missing.
#
# PREREQUISITE: install the Telegram app (https://telegram.org/apps —
# mobile, desktop, or web). The setup below is done INSIDE Telegram:
#   1. Open a chat with @BotFather → send /newbot → follow prompts →
#      copy the token shown ("123456:ABC-…") into TELEGRAM_BOT_TOKEN.
#   2. Search for your new bot → open the chat → send /start, then send any
#      text message (e.g. "hi"). Telegram's getUpdates endpoint only returns
#      real messages — pressing /start alone may not surface the chat.
#   3. In any browser, visit https://api.telegram.org/bot<TOKEN>/getUpdates
#      and copy the "chat":{"id": …} value (positive int for direct chats)
#      into TELEGRAM_CHAT_ID. If the response is {"result":[]}, send another
#      message in Telegram and refresh.
#
# Security: outbound HTTPS only, no public URL needed, never sends finding
# bodies (only counts and short HIR situation strings), dedups identical
# alerts within 30 min. Audit log at logs/telegram_audit.log.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Slack bridge (optional) ──────────────────────────────────────────────────
# Same outbound-only alerts via a Slack Incoming Webhook. Leave blank to
# disable. Any combination of Telegram/Slack/Discord can be enabled at once.
#
# Setup (inside Slack):
#   1. https://api.slack.com/apps → Create New App → From scratch.
#   2. Activate Incoming Webhooks → Add New Webhook to Workspace.
#   3. Pick the channel that should receive alerts (a private DM is fine).
#   4. Copy the webhook URL — it looks like
#      https://hooks.slack.com/services/T…/B…/…  → paste below.
#
# Security: outbound HTTPS only, never sends finding bodies, dedups identical
# alerts within 30 min. Audit log at logs/slack_audit.log.
SLACK_WEBHOOK_URL=

# ── Discord bridge (optional) ────────────────────────────────────────────────
# Same outbound-only alerts via a Discord channel webhook. Leave blank to
# disable.
#
# Setup (inside Discord):
#   1. Open the channel that should receive alerts.
#   2. Channel settings → Integrations → Webhooks → New Webhook.
#   3. Name it (e.g. "agent-smith"), confirm the channel, copy the webhook URL.
#      It looks like https://discord.com/api/webhooks/<id>/<token>.
#
# Security: outbound HTTPS only, @everyone/@here mentions disabled defensively,
# dedups identical alerts within 30 min. Audit log at logs/discord_audit.log.
DISCORD_WEBHOOK_URL=

# ── Periodic status updates ──────────────────────────────────────────────────
# Every N minutes the dashboard pushes a high-level scan summary
# (finding counts by severity, skills run, coverage %, activity, cost,
# runtime) to every configured notifier sink above. The summary contains
# NO target, NO finding titles, NO endpoint paths — counts and percentages
# only.
#
# Defaults to 30 minutes. Set to 0 to disable status pings entirely; idle
# scans (no active session) never trigger a ping regardless of the value.
STATUS_UPDATE_INTERVAL_MINUTES=30
